<Window x:Class="WindSonic.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="WindSonic"
        Icon="pack://application:,,,/Assets/WindSonic.ico"
        Width="1260"
        Height="830"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="#070708"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Loaded="MainWindow_Loaded"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        SourceInitialized="MainWindow_SourceInitialized">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="44" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#B3121316" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="TextSoftBrush" Color="#A2A8B1" />

    <Style x:Key="Card" TargetType="Border">
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="Btn" TargetType="Button">
      <Setter Property="Foreground" Value="#F8F8FA" />
      <Setter Property="Background" Value="#C0191C23" />
      <Setter Property="BorderBrush" Value="#29FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="B" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="11">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="B" Property="Background" Value="#D0222630" /></Trigger>
              <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="TabControl">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="#F4F6FA" />
      <Setter Property="Background" Value="#6F13161B" />
      <Setter Property="BorderBrush" Value="#22FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10,10,0,0" Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="#D0182224" />
                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4B2CE8D8" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#36FFFFFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Foreground" Value="#F6F6F8" />
      <Setter Property="Background" Value="#B60D0F13" />
      <Setter Property="BorderBrush" Value="#28FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="CaretBrush" Value="#2CE8D8" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style TargetType="ListBoxItem">
      <Setter Property="Margin" Value="0,0,0,8" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="Row" CornerRadius="12" Padding="11" Background="#8E101116" BorderBrush="#1CFFFFFF" BorderThickness="1"><ContentPresenter /></Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True"><Setter TargetName="Row" Property="Background" Value="#C1141D1E" /><Setter TargetName="Row" Property="BorderBrush" Value="#602CE8D8" /></Trigger>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Row" Property="BorderBrush" Value="#30FFFFFF" /></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#060708" Offset="0" /><GradientStop Color="#090A0D" Offset="1" /></LinearGradientBrush>
    </Grid.Background>

    <Canvas IsHitTestVisible="False">
      <Ellipse Width="360" Height="360" Canvas.Left="-55" Canvas.Top="-50"><Ellipse.Fill><RadialGradientBrush><GradientStop Color="#2930A4A0" Offset="0" /><GradientStop Color="#0030A4A0" Offset="1" /></RadialGradientBrush></Ellipse.Fill></Ellipse>
      <Ellipse Width="320" Height="320" Canvas.Left="860" Canvas.Top="140"><Ellipse.Fill><RadialGradientBrush><GradientStop Color="#26B7607A" Offset="0" /><GradientStop Color="#00B7607A" Offset="1" /></RadialGradientBrush></Ellipse.Fill></Ellipse>
    </Canvas>

    <Border Margin="18" CornerRadius="22" Background="#A9090A0C" BorderBrush="#24FFFFFF" BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="15,11" BorderBrush="#18FFFFFF" BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
              <Border Width="34" Height="34" CornerRadius="11" Background="#18202327" BorderBrush="#22FFFFFF" BorderThickness="1"><Ellipse Width="12" Height="12" Fill="#2CE8D8" Opacity="0.9" /></Border>
              <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="WindSonic" FontFamily="Bahnschrift SemiCondensed" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Native WPF music player: Apple/iTunes search + YouTube audio" FontSize="11" Foreground="{StaticResource TextSoftBrush}" />
              </StackPanel>
            </StackPanel>
            <Border Grid.Column="1" Margin="14,0,0,0" Padding="11,7" MaxWidth="430" CornerRadius="11" Background="#76101417" BorderBrush="#20FFFFFF" BorderThickness="1" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True"><TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#D5DAE3" TextTrimming="CharacterEllipsis" /></Border>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
              <Button Width="36" Height="28" Margin="4,0,0,0" Padding="0" Content="_" Style="{StaticResource Btn}" Click="MinimizeButton_Click" FontFamily="Consolas" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
              <Button Width="36" Height="28" Margin="4,0,0,0" Padding="0" Content="[]" Style="{StaticResource Btn}" Click="MaxRestoreButton_Click" FontFamily="Consolas" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
              <Button Width="36" Height="28" Margin="4,0,0,0" Padding="0" Content="X" Style="{StaticResource Btn}" Click="CloseButton_Click" FontFamily="Consolas" Background="#A0322026" BorderBrush="#55FF8891" shell:WindowChrome.IsHitTestVisibleInChrome="True" />
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.95*" MinWidth="520" />
            <ColumnDefinition Width="1.35*" MinWidth="400" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>

          <Border Grid.Row="0" Grid.Column="0" Margin="0,0,12,12" Style="{StaticResource Card}">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Find a Song" FontFamily="Bahnschrift SemiCondensed" FontSize="18" FontWeight="Bold" />
                <TextBlock Margin="0,4,0,0" Text="Uses Apple iTunes Search API metadata (no login). Double-click to play, or queue songs into playlists." FontSize="12" Foreground="{StaticResource TextSoftBrush}" />
                <TextBox x:Name="SearchInput" Margin="0,10,0,0" Height="40" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>
              <Button Grid.Column="1" Margin="0,26,8,0" Height="40" MinWidth="94" Content="Search" Command="{Binding SearchCommand}" IsDefault="True" Style="{StaticResource Btn}" Background="#D0173B3A" BorderBrush="#4B2CE8D8" />
              <Button Grid.Column="2" Margin="0,26,8,0" Height="40" MinWidth="128" Content="Play Selected" Command="{Binding PlaySelectedCommand}" Style="{StaticResource Btn}" />
              <StackPanel Grid.Column="3" Margin="0,26,0,0">
                <Button Height="28" MinWidth="116" Content="Add to Queue" Command="{Binding QueueSelectedCommand}" Style="{StaticResource SmallBtn}" />
                <Button Margin="0,4,0,0" Height="28" MinWidth="116" Content="Queue Top 10" Command="{Binding QueueTopResultsCommand}" Style="{StaticResource SmallBtn}" />
              </StackPanel>
            </Grid>
          </Border>
          <Border Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" Style="{StaticResource Card}">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="Song Results" FontFamily="Bahnschrift SemiCondensed" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding SearchSummary}" Foreground="{StaticResource TextSoftBrush}" VerticalAlignment="Center" />
              </Grid>
              <ListBox x:Name="ResultsList" Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedTrack}" MouseDoubleClick="ResultsList_MouseDoubleClick" Background="Transparent" BorderThickness="0" ScrollViewer.CanContentScroll="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemsPanel><ItemsPanelTemplate><VirtualizingStackPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding Subtitle}" FontSize="12" Foreground="{StaticResource TextSoftBrush}" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <Border Grid.Column="1" Margin="10,0,0,0" Padding="8,3" CornerRadius="9" Background="#4A121419" BorderBrush="#1AFFFFFF" BorderThickness="1" VerticalAlignment="Center"><TextBlock Text="{Binding DurationLabel}" FontFamily="Consolas" FontSize="11" Foreground="#D8DDE5" /></Border>
                      <Button Grid.Column="2"
                              Margin="10,0,0,0"
                              MinWidth="58"
                              Height="28"
                              Padding="10,4"
                              VerticalAlignment="Center"
                              Content="Play"
                              Style="{StaticResource Btn}"
                              Background="#D0173B3A"
                              BorderBrush="#4B2CE8D8"
                              Click="SongPlayButton_Click" />
                      <Button Grid.Column="3"
                              Margin="8,0,0,0"
                              MinWidth="64"
                              Height="28"
                              Padding="10,4"
                              VerticalAlignment="Center"
                              Content="Queue"
                              Style="{StaticResource SmallBtn}"
                              Click="SongQueueButton_Click" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>

          <Grid Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,0,0,12" Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Now Playing" FontFamily="Bahnschrift SemiCondensed" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Margin="0,10,0,0" Text="{Binding NowPlayingTitle}" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0" Text="{Binding NowPlayingMeta}" Foreground="{StaticResource TextSoftBrush}" TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0" Text="{Binding NowPlayingSource}" FontSize="11" Foreground="#C6CFDA" TextWrapping="Wrap" />

                <Grid Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <ComboBox Grid.Column="0"
                            Margin="0,0,8,0"
                            Height="32"
                            Padding="6,2"
                            ItemsSource="{Binding SourceOptions}"
                            SelectedItem="{Binding SelectedSourceOption, Mode=TwoWay}"
                            DisplayMemberPath="PickerLabel"
                            Background="#A70E1116"
                            Foreground="#EEF2F8"
                            BorderBrush="#28FFFFFF"
                            BorderThickness="1"
                            IsTextSearchEnabled="False" />
                  <Button Grid.Column="1" Margin="0,0,6,0" Content="Use Source" Command="{Binding PlaySelectedSourceCommand}" Style="{StaticResource SmallBtn}" />
                  <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshSourceOptionsCommand}" Style="{StaticResource SmallBtn}" />
                </Grid>
                <TextBlock Margin="0,6,0,0" Text="{Binding SourcePickerSummary}" FontSize="10.5" Foreground="{StaticResource TextSoftBrush}" TextWrapping="Wrap" />

                <Grid Margin="0,14,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding PlaybackPositionLabel}" FontFamily="Consolas" Foreground="{StaticResource TextSoftBrush}" />
                  <Slider x:Name="SeekSlider"
                          Grid.Column="1"
                          Margin="9,0"
                          Height="18"
                          VerticalAlignment="Center"
                          Minimum="0"
                          Maximum="{Binding PlaybackDurationSeconds, Mode=OneWay}"
                          Value="{Binding SeekBarSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsMoveToPointEnabled="True"
                          PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"
                          PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"
                          PreviewKeyUp="SeekSlider_PreviewKeyUp" />
                  <TextBlock Grid.Column="2" Text="{Binding PlaybackDurationLabel}" FontFamily="Consolas" Foreground="{StaticResource TextSoftBrush}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Row="1" Margin="0,0,0,12" Style="{StaticResource Card}">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <TextBlock Text="Playback Controls" FontFamily="Bahnschrift SemiCondensed" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="{Binding PlaybackStateText}" Foreground="{StaticResource TextSoftBrush}" VerticalAlignment="Center" />
                </Grid>
                <UniformGrid Columns="4" Margin="0,10,0,0">
                  <Button Margin="0,0,6,0" Content="Prev" Command="{Binding PreviousTrackCommand}" Style="{StaticResource SmallBtn}" />
                  <Button Margin="6,0,6,0" Content="{Binding PlayPauseButtonText}" Command="{Binding PauseResumeCommand}" Style="{StaticResource Btn}" />
                  <Button Margin="6,0,6,0" Content="Next" Command="{Binding NextTrackCommand}" Style="{StaticResource SmallBtn}" />
                  <Button Margin="6,0,0,0" Content="Stop" Command="{Binding StopCommand}" Style="{StaticResource SmallBtn}" />
                </UniformGrid>
                <UniformGrid Columns="3" Margin="0,8,0,0">
                  <Button Margin="0,0,6,0" Content="{Binding ShuffleButtonText}" Command="{Binding ToggleShuffleCommand}" Style="{StaticResource SmallBtn}" />
                  <Button Margin="6,0,6,0" Content="{Binding RepeatButtonText}" Command="{Binding CycleRepeatCommand}" Style="{StaticResource SmallBtn}" />
                  <Button Margin="6,0,0,0" Content="Surprise Mix" Command="{Binding SurpriseMixCommand}" Style="{StaticResource SmallBtn}" />
                </UniformGrid>
                <TextBlock Margin="0,8,0,0" Text="{Binding QueueModeSummary}" FontSize="11" Foreground="{StaticResource TextSoftBrush}" />
                <TextBlock Margin="0,2,0,0" Text="{Binding UpNextLabel}" FontSize="11" Foreground="#C7CFD8" TextWrapping="Wrap" />
                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <TextBlock Text="Volume" VerticalAlignment="Center" Foreground="{StaticResource TextSoftBrush}" />
                  <Slider Grid.Column="1" Margin="10,0" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                  <TextBlock Grid.Column="2" Text="{Binding Volume}" FontFamily="Consolas" VerticalAlignment="Center" />
                </Grid>
                <TextBlock Margin="0,8,0,0" Text="{Binding ResolveSummary}" FontSize="11" Foreground="{StaticResource TextSoftBrush}" />
                <Border Margin="0,10,0,0" Padding="10" CornerRadius="10" Background="#52101417" BorderBrush="#1AFFFFFF" BorderThickness="1">
                  <StackPanel>
                    <TextBlock Text="Optimized mode: YouTube playback is audio-only using native libVLC, so no video surface is rendered while you game." FontSize="11" Foreground="#CFD6DF" TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding EngineModeLabel}" FontSize="10.5" Foreground="#AFC0D0" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
            <Border Grid.Row="2" Style="{StaticResource Card}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <TextBlock Text="Queue &amp; Library" FontFamily="Bahnschrift SemiCondensed" FontSize="16" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="{Binding QueueSummary}" Foreground="{StaticResource TextSoftBrush}" VerticalAlignment="Center" />
                </Grid>

                <TabControl Grid.Row="1" Margin="0,10,0,0">
                  <TabItem Header="Queue">
                    <Grid Margin="0,8,0,0">
                      <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                      <TextBlock Text="{Binding QueuePositionLabel}" Foreground="{StaticResource TextSoftBrush}" />
                      <ListBox x:Name="QueueList"
                               Grid.Row="1"
                               Margin="0,8,0,0"
                               ItemsSource="{Binding QueueItems}"
                               SelectedItem="{Binding SelectedQueueItem}"
                               Background="Transparent"
                               BorderThickness="0"
                               MouseDoubleClick="QueueList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid>
                              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0" Text="{Binding Subtitle}" FontSize="11" Foreground="{StaticResource TextSoftBrush}" TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                              <Border Grid.Column="1" Margin="8,0,0,0" Padding="8,3" CornerRadius="8" Background="#4A121419" BorderBrush="#1AFFFFFF" BorderThickness="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DurationLabel}" FontFamily="Consolas" FontSize="10.5" />
                              </Border>
                              <Button Grid.Column="2" Margin="8,0,0,0" Content="Play" Style="{StaticResource SmallBtn}" Background="#D0173B3A" BorderBrush="#4B2CE8D8" Click="QueueRowPlayButton_Click" />
                              <Button Grid.Column="3" Margin="6,0,0,0" Content="X" Width="28" Style="{StaticResource SmallBtn}" Click="QueueRowRemoveButton_Click" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                      <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                        <Button Margin="0,0,6,6" Content="Add Selected" Command="{Binding QueueSelectedCommand}" Style="{StaticResource SmallBtn}" />
                        <Button Margin="0,0,6,6" Content="Queue Top 10" Command="{Binding QueueTopResultsCommand}" Style="{StaticResource SmallBtn}" />
                        <Button Margin="0,0,6,6" Content="Shuffle Queue" Command="{Binding ShuffleQueueCommand}" Style="{StaticResource SmallBtn}" />
                        <Button Margin="0,0,6,6" Content="Save as Playlist" Command="{Binding SaveQueueAsPlaylistCommand}" Style="{StaticResource SmallBtn}" />
                        <Button Margin="0,0,0,6" Content="Clear Queue" Command="{Binding ClearQueueCommand}" Style="{StaticResource SmallBtn}" />
                      </WrapPanel>
                    </Grid>
                  </TabItem>

                  <TabItem Header="Playlists">
                    <Grid Margin="0,8,0,0">
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.0*" MinHeight="90" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.4*" MinHeight="140" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="34" Margin="0,0,8,0" Text="{Binding DraftPlaylistName, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Margin="0,0,8,0" Content="Create" Command="{Binding CreatePlaylistCommand}" Style="{StaticResource SmallBtn}" />
                        <Button Grid.Column="2" Content="Delete" Command="{Binding DeletePlaylistCommand}" Style="{StaticResource SmallBtn}" />
                      </Grid>

                      <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="{Binding PlaylistSummary}" Foreground="{StaticResource TextSoftBrush}" FontSize="11" />
                      <ListBox x:Name="PlaylistsList"
                               Grid.Row="2"
                               Margin="0,6,0,0"
                               ItemsSource="{Binding Playlists}"
                               SelectedItem="{Binding SelectedPlaylist}"
                               Background="Transparent"
                               BorderThickness="0"
                               ScrollViewer.VerticalScrollBarVisibility="Auto"
                               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <StackPanel>
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                              <TextBlock Margin="0,2,0,0" Text="{Binding Summary}" FontSize="11" Foreground="{StaticResource TextSoftBrush}" />
                            </StackPanel>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>

                      <StackPanel Grid.Row="3" Margin="0,8,0,0">
                        <WrapPanel>
                          <Button Margin="0,0,6,6" Content="Add Search Selected" Command="{Binding AddSelectedResultToPlaylistCommand}" Style="{StaticResource SmallBtn}" />
                          <Button Margin="0,0,6,6" Content="Load + Play" Command="{Binding LoadPlaylistToQueueCommand}" Style="{StaticResource SmallBtn}" />
                          <Button Margin="0,0,0,6" Content="Append to Queue" Command="{Binding AppendPlaylistToQueueCommand}" Style="{StaticResource SmallBtn}" />
                        </WrapPanel>

                        <Grid Margin="0,2,0,0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBox Grid.Column="0"
                                   Height="32"
                                   Margin="0,0,8,0"
                                   Text="{Binding SpotifyPlaylistImportInput, UpdateSourceTrigger=PropertyChanged}"
                                   ToolTip="Paste a Spotify playlist URL or spotify:playlist:... URI" />
                          <Button Grid.Column="1"
                                  Content="Import Spotify Playlist"
                                  Command="{Binding ImportSpotifyPlaylistCommand}"
                                  Style="{StaticResource SmallBtn}"
                                  Background="#D0173B3A"
                                  BorderBrush="#4B2CE8D8" />
                        </Grid>

                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding SpotifyPlaylistImportSummary}"
                                   FontSize="10.5"
                                   Foreground="{StaticResource TextSoftBrush}"
                                   TextWrapping="Wrap" />

                        <Expander Margin="0,6,0,0"
                                  Header="Advanced: Spotify API keys (optional for full imports)"
                                  Foreground="#DCE5EF">
                          <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="Client ID" Foreground="{StaticResource TextSoftBrush}" />
                            <TextBox Grid.Column="1"
                                     Height="30"
                                     Text="{Binding SpotifyClientId, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" VerticalAlignment="Center" Margin="0,8,8,0" Text="Client Secret" Foreground="{StaticResource TextSoftBrush}" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Height="30"
                                     Margin="0,8,0,0"
                                     Text="{Binding SpotifyClientSecret, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                              <Button Content="Save Keys" Command="{Binding SaveCredentialsCommand}" Style="{StaticResource SmallBtn}" />
                              <TextBlock Margin="8,4,0,0" FontSize="10.5" Foreground="{StaticResource TextSoftBrush}" Text="Only needed if Spotify page import doesn't load the full playlist." />
                            </StackPanel>
                          </Grid>
                        </Expander>
                      </StackPanel>

                      <TextBlock Grid.Row="4" Margin="0,2,0,0" Text="{Binding SelectedPlaylistSummary}" Foreground="{StaticResource TextSoftBrush}" FontSize="11" />
                      <ListBox x:Name="PlaylistTracksList"
                               Grid.Row="5"
                               Margin="0,6,0,0"
                               ItemsSource="{Binding SelectedPlaylistTracks}"
                               SelectedItem="{Binding SelectedPlaylistTrack}"
                               Background="Transparent"
                               BorderThickness="0"
                               ScrollViewer.VerticalScrollBarVisibility="Auto"
                               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                               MouseDoubleClick="PlaylistTracksList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0" Text="{Binding Subtitle}" FontSize="11" Foreground="{StaticResource TextSoftBrush}" TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                              <Border Grid.Column="1" Margin="8,0,0,0" Padding="8,3" CornerRadius="8" Background="#4A121419" BorderBrush="#1AFFFFFF" BorderThickness="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DurationLabel}" FontFamily="Consolas" FontSize="10.5" />
                              </Border>
                              <Button Grid.Column="2" Margin="8,0,0,0" Content="Play" Style="{StaticResource SmallBtn}" Background="#D0173B3A" BorderBrush="#4B2CE8D8" Click="PlaylistTrackPlayButton_Click" />
                              <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="6,0,0,0">
                                <Button Content="+" Width="28" Style="{StaticResource SmallBtn}" Click="PlaylistTrackQueueButton_Click" />
                                <Button Margin="4,0,0,0" Content="X" Width="28" Style="{StaticResource SmallBtn}" Click="PlaylistTrackRemoveButton_Click" />
                              </StackPanel>
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>

                      <TextBlock Grid.Row="6" Margin="0,8,0,0" Text="Tip: double-click playlist tracks to play instantly." FontSize="10.5" Foreground="{StaticResource TextSoftBrush}" />
                    </Grid>
                  </TabItem>

                  <TabItem Header="Recents">
                    <Grid Margin="0,8,0,0">
                      <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                      <TextBlock Text="{Binding RecentsSummary}" Foreground="{StaticResource TextSoftBrush}" />
                      <ListBox x:Name="RecentsList"
                               Grid.Row="1"
                               Margin="0,8,0,0"
                               ItemsSource="{Binding RecentTracks}"
                               SelectedItem="{Binding SelectedRecentTrack}"
                               Background="Transparent"
                               BorderThickness="0"
                               MouseDoubleClick="RecentsList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid>
                              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="{Binding Track.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                  <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource TextSoftBrush}" TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding Track.Artists, Mode=OneWay}" /><Run Text="  •  " /><Run Text="{Binding PlayedAtLabel, Mode=OneWay}" />
                                  </TextBlock>
                              </StackPanel>
                              <Button Grid.Column="1" Margin="8,0,0,0" Content="Play" Style="{StaticResource SmallBtn}" Background="#D0173B3A" BorderBrush="#4B2CE8D8" Click="RecentTrackPlayButton_Click" />
                              <Button Grid.Column="2" Margin="6,0,0,0" Content="Queue" Style="{StaticResource SmallBtn}" Click="RecentTrackQueueButton_Click" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                      <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                        <Button Margin="0,0,6,6" Content="Surprise Mix" Command="{Binding SurpriseMixCommand}" Style="{StaticResource SmallBtn}" />
                        <Button Margin="0,0,0,6" Content="Clear Recents" Command="{Binding ClearRecentsCommand}" Style="{StaticResource SmallBtn}" />
                      </WrapPanel>
                    </Grid>
                  </TabItem>
                </TabControl>

                <TextBlock Grid.Row="2" Margin="0,8,0,0" FontSize="10.5" Foreground="{StaticResource TextSoftBrush}" TextWrapping="Wrap">
                  <Run Text="No Spotify setup needed. Search uses Apple’s public iTunes Search API metadata. " />
                  <Hyperlink NavigateUri="https://developer.apple.com/library/archive/documentation/AudioVideo/Conceptual/iTuneSearchAPI/" RequestNavigate="HelpLink_RequestNavigate">Docs</Hyperlink>
                </TextBlock>
              </Grid>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>

